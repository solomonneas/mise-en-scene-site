---
import { NAV_LINKS, EXTERNAL } from '../lib/site.ts';
import ThemeToggle from './ThemeToggle.astro';
---
<nav class="flex items-center gap-6 px-6 md:px-10 py-4 border-b text-sm" style="border-color: var(--hairline);">
  <a href="/" class="font-mono font-medium text-base">MISE-EN-SCENE<span style="color: var(--accent);">_</span></a>
  {NAV_LINKS.map((l) => <a href={l.href} class="hidden sm:inline" style="color: var(--text-muted);">{l.label}</a>)}
  <span class="flex-1"></span>
  <a href={EXTERNAL.github} class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border"
    style="border-color: var(--hairline); background: var(--bg-panel);">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="var(--accent)" aria-hidden="true">
      <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
    </svg>
    <span>Star on GitHub</span>
  </a>
  <ThemeToggle />
</nav>
