---
import { NAV_LINKS, EXTERNAL } from '../lib/site.ts';
import ThemeToggle from './ThemeToggle.astro';
---
<nav class="flex items-center gap-6 px-6 md:px-10 py-4 border-b text-sm" style="border-color: var(--hairline);">
  <a href="/" class="font-mono font-medium text-base">MISE-EN-SCENE<span style="color: var(--accent);">_</span></a>
  {NAV_LINKS.map((l) => <a href={l.href} class="hidden sm:inline" style="color: var(--text-muted);">{l.label}</a>)}
  <span class="flex-1"></span>
  <a href={EXTERNAL.stargazers} class="inline-flex items-center" aria-label="Star on GitHub">
    <img class="stars-badge-dark" src={EXTERNAL.starsBadgeDark} alt="GitHub stars" height="32" loading="lazy" decoding="async" />
    <img class="stars-badge-light" src={EXTERNAL.starsBadgeLight} alt="GitHub stars" height="32" loading="lazy" decoding="async" />
  </a>
  <ThemeToggle />
</nav>
